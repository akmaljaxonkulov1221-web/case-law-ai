# Case-Law AI Production Environment Variables

# Application
APP_NAME=Case-Law AI Platform
VERSION=1.0.0
NODE_ENV=production
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://caselaw_user:caselaw_password@postgres:5432/caselaw_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Security Configuration
SECRET_KEY=your-super-secret-production-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1
OPENAI_ORGANIZATION=your-openai-org-id

# LangChain Configuration
LANGCHAIN_VERBOSE=false
LANGCHAIN_DEBUG=false
LANGCHAIN_TRACING_V2=false

# Vector Database (ChromaDB)
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=caselaw_laws
CHROMA_COLLECTION_CASES=caselaw_cases

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=20

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=/app/logs/caselaw_ai.log

# AI Processing Configuration
MAX_CONCURRENT_REQUESTS=50
AI_REQUEST_TIMEOUT=120
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=5

# RAG Configuration
RAG_TOP_K=10
RAG_SCORE_THRESHOLD=0.7
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_MAX_TOKENS=2000

# Weakness Detection Configuration
WEAKNESS_CONFIDENCE_THRESHOLD=0.8
WEAKNESS_MIN_OCCURRENCES=3
WEAKNESS_ANALYSIS_PERIOD=30d

# Scenario Generation Configuration
SCENARIO_MAX_BRANCHES=3
SCENARIO_MIN_PROBABILITY=0.1
SCENARIO_MAX_TOKENS=3000

# NextAuth Configuration
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_REFRESH_SECRET=your-nextauth-refresh-secret-key

# CORS Configuration
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring & Analytics
ENABLE_MONITORING=true
SENTRY_DSN=your-sentry-dsn
ANALYTICS_ID=your-analytics-id

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@your-domain.com

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
FORCE_HTTPS=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# Performance Tuning
WORKERS=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65
MAX_REQUEST_SIZE=10485760

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_GAMIFICATION=true
ENABLE_COMMUNITY=true
ENABLE_ANALYTICS=true
ENABLE_MONETIZATION=true

# Security Headers
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Development Overrides (set to false in production)
ENABLE_DEBUG_ROUTES=false
ENABLE_SWAGGER_UI=false
ENABLE_API_DOCS=false
