# Case-Law AI Core Environment Variables

# Application
APP_NAME=Case-Law AI Core
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/caselaw_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1

# LangChain
LANGCHAIN_VERBOSE=false
LANGCHAIN_DEBUG=false

# Vector Database (Chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=caselaw_laws

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# AI Processing
MAX_CONCURRENT_REQUESTS=10
AI_REQUEST_TIMEOUT=60

# RAG Settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# Weakness Detection
WEAKNESS_CONFIDENCE_THRESHOLD=0.8
WEAKNESS_MIN_OCCURRENCES=3

# Scenario Generation
SCENARIO_MAX_BRANCHES=3
SCENARIO_MIN_PROBABILITY=0.1
